{
  "name": "felixai",
  "version": "0.1.0",
  "description": "Local Codex SDK orchestrator for batch task execution with checkpoints.",
  "type": "module",
  "bin": {
    "felixai": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node dist/job-manager.test.js"
  },
  "keywords": [
    "codex",
    "openai",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.118.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
